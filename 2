body { background:#f8f9fa; }
.modal-hidden{ display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); align-items:center; justify-content:center; }
.modal-box{ background:#fff; padding:12px; border-radius:8px; width:90%; max-width:420px; text-align:center; }
#video{ width:100%; height:auto; border-radius:6px; background:#000; }
.list-item{ background:#fff; padding:10px; margin-bottom:8px; border-radius:6px; box-shadow:0 1px 2px rgba(0,0,0,0.05); }
.actions button{ margin-left:6px; }
