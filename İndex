<!doctype html>
<html lang="tr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
  <title>Mobil Stok</title>
  <link rel="manifest" href="/manifest.json">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Mobil Stok">
  <link rel="stylesheet" href="styles.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <div class="container py-3">
    <header class="d-flex align-items-center mb-3">
      <h3 class="m-0">Mobil Stok</h3>
      <div class="ms-auto text-end">
        <button id="btnExport" class="btn btn-sm btn-outline-secondary">CSV Dışa Aktar</button>
        <label class="btn btn-sm btn-outline-primary mb-0">
          CSV İçe Al <input id="fileImport" type="file" accept=".csv" hidden>
        </label>
      </div>
    </header>

    <section class="mb-3">
      <form id="formAdd" class="row g-2">
        <div class="col-8">
          <input id="inName" class="form-control" placeholder="Ürün adı, marka veya barkod" required>
        </div>
        <div class="col-4 d-flex">
          <input id="inQty" type="number" min="0" class="form-control me-2" value="1">
          <button class="btn btn-success" type="submit">Ekle</button>
        </div>
        <div class="col-12">
          <div class="d-flex gap-2 mt-1">
            <input id="inBarcode" class="form-control" placeholder="Barkod (isteğe bağlı)">
            <button id="btnScan" type="button" class="btn btn-outline-secondary">Barkod Tara</button>
          </div>
        </div>
      </form>
    </section>

    <section class="mb-3">
      <div class="d-flex mb-2">
        <input id="q" class="form-control me-2" placeholder="Ara: isim, barkod">
        <select id="filter" class="form-select" style="width:160px">
          <option value="all">Tümü</option>
          <option value="low">Düşük Stok</option>
        </select>
      </div>
      <div id="list"></div>
    </section>

    <footer class="text-muted small">
      Bu uygulama verileri sadece cihazında saklar. Cihazlar arası senkronizasyon istersen sunucu kurarız.
    </footer>
  </div>

  <!-- Modallar / kamera video -->
  <div id="scanModal" class="modal-hidden">
    <div class="modal-box">
      <button id="closeScan" class="btn-close">×</button>
      <p>Kamera ile tarama</p>
      <video id="video" autoplay playsinline></video>
      <div id="scanInfo" class="small text-muted mt-2"></div>
    </div>
  </div>

  <script src="app.js"></script>
</body>
</html>
